{% from "components/tooltip.jinja2" import tooltip %}

{% macro seq_request_status_bar(seq_request) -%}
{% if seq_request.status == C.SeqRequestStatus.DRAFT %}
<div class="progress" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100" {{ tooltip(C.SeqRequestStatus.DRAFT.description, position='top', category='warning') }}>
    <div class="progress-bar progress-bar-striped bg-transparent text-muted" style="width: 100%">
        {{ C.SeqRequestStatus.DRAFT.label }} {{ C.SeqRequestStatus.DRAFT.icon | safe }}
    </div>
</div>
{% elif seq_request.status == C.SeqRequestStatus.ARCHIVED %}
<div class="progress" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100" {{ tooltip(C.SeqRequestStatus.DRAFT.description, position='top', category='warning') }}>
<div class="progress-bar progress-bar-striped bg-info text-dark" style="width: 100%">
        {{ C.SeqRequestStatus.ARCHIVED.label }} {{ C.SeqRequestStatus.ARCHIVED.icon | safe }}
    </div>
</div>
{% elif seq_request.status == C.SeqRequestStatus.FAILED %}
<div class="progress" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100" {{ tooltip(C.SeqRequestStatus.FAILED.description, position='top', category='warning') }}>
    <div class="progress-bar progress-bar-striped bg-danger" style="width: 100%">
        {{ C.SeqRequestStatus.FAILED.label }} {{ C.SeqRequestStatus.FAILED.icon | safe }}
    </div>
</div>
{% else %}
<div class="progress-stacked">
    {% set fill_pct = (100 / C.SeqRequestStatus.FINISHED.id + 1) %}
    {% for status_id in range(1, C.SeqRequestStatus.FINISHED.id + 1) %}
    {% set status = C.SeqRequestStatus.get(status_id) %}
    <div class="progress" role="progressbar" aria-valuenow="{{ fill_pct }}" aria-valuemin="0" aria-valuemax="100" style="width: {{ fill_pct }}%"
    {{ tooltip(status.description, position='top', category='warning') }}>
        {% if seq_request.status >= status %}
        <div class="progress-bar bg-tab-10-{{ status_id }}">
        {% else %}
        <div class="progress-bar progress-bar-striped text-muted  bg-transparent">
        {% endif %}
        {{ status.label }} {{ status.icon | safe }}
        </div>
    </div>
    {% endfor %}
</div>
{% endif %}
{%- endmacro %}

