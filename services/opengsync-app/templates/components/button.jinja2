{% from "components/tooltip.jinja2" import tooltip as tooltip_func %}

{% macro confirm_action_button(text, title, url, class="btn", color="primary", container="button", method="hx-get", body="Do you want to proceed?", icon="warning", disabled=false, tooltip=none, disabled_tooltip=none, tooltip_position="top") %}
{% if disabled and disabled_tooltip %}
<span {{ tooltip_func(disabled_tooltip, tooltip_position, "warning") }}>
{% endif %}
<{{ container }} type="button" class="{{ class }} {% if class == "btn" %}btn-{{ color }}{% endif %}"
    {% if not disabled %}
    {{ method }}="{{ url }}"
    _='on htmx:confirm(issueRequest)
        halt the event
        call Swal.fire({
            title: {{ title | tojson | forceescape }},
            icon: "{{ icon }}",
            showDenyButton: true,
            text: {{ body | tojson | forceescape }},
            confirmButtonText: "Yes",
            denyButtonText: "No"
        })
        if result.isConfirmed issueRequest()'
    {% else %}disabled{%endif%} {% if tooltip %}{{ tooltip_func(tooltip, tooltip_position, color) }}{% endif %}>{{ text }}</{{ container }}>
{% if disabled and disabled_tooltip %}
</span>
{% endif %}
{% endmacro %}

{% macro modal_button(text, url, container="button", class="btn", size="xl", disabled=false, method="hx-get", tooltip=none, color="primary", tooltip_position="top", disabled_tooltip=none) %}
{% if disabled and disabled_tooltip %}
<span {{ tooltip_func(disabled_tooltip, tooltip_position, "warning") }}>
{% endif %}
<{{ container }} type="button" class="{{ class }} {% if class == "btn" %}btn-{{ color }}{% endif %}" {{ method }}="{{ url }}"
data-bs-toggle="modal" data-bs-target="#{{ size }}-modal" hx-target="#{{ size }}-modal-content" hx-swap="innerHTML"
{% if disabled %}disabled{% endif %}>
    <span {% if tooltip and not disabled %}{{ tooltip_func(tooltip, tooltip_position, color) }}{% endif %}>{{ text }}</span>
</{{ container }}>
{% if disabled and disabled_tooltip %}
</span>
{% endif %}
{% endmacro %}